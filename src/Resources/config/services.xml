<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <defaults autowire="true" autoconfigure="true" public="false"/>

        <!-- Commands -->
        <service id="JoostGroen\Mentat\Service\Greeter"/>

        <service id="JoostGroen\Mentat\Command\GreetCommand"/>

        <service id="JoostGroen\Mentat\Command\ExtractPdfCommand">
            <argument type="service" id="JoostGroen\Mentat\Service\PdfTextExtractor"/>
        </service>

        <service id="JoostGroen\Mentat\Command\TestLlmCommand">
            <argument type="service" id="JoostGroen\Mentat\Service\Llm\LlmClientInterface"/>
        </service>

        <service id="JoostGroen\Mentat\Command\SeedCategoryCommand">
            <argument type="service" id="mentat_category.repository"/>
        </service>

        <service id="JoostGroen\Mentat\Command\PromptTestCommand">
            <argument type="service" id="mentat_category.repository"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Llm\PromptBuilder"/>
        </service>

        <service id="JoostGroen\Mentat\Command\DraftListingCommand">
            <argument type="service" id="mentat_category.repository"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Llm\PromptBuilder"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Llm\LlmClientInterface"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Llm\ResultValidator"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Listing\ProductDraftWriter"/>
        </service>
        

        <!-- Entity Definitions -->
        <service id="JoostGroen\Mentat\Core\Content\MentatCategory\MentatCategoryDefinition">
            <tag name="shopware.entity.definition"/>
        </service>

        <service id="JoostGroen\Mentat\Command\CreateCategoryCommand">
            <argument type="service" id="mentat_category.repository"/>
        </service>

        <service id="Smalot\PdfParser\Parser"/>

        <service id="JoostGroen\Mentat\Service\PdfTextExtractor">
            <argument type="service" id="Smalot\PdfParser\Parser"/>
        </service>

        <service id="JoostGroen\Mentat\Service\Llm\GeminiClient"/>

        <service id="JoostGroen\Mentat\Service\Llm\LlmClientInterface"
                alias="JoostGroen\Mentat\Service\Llm\GeminiClient"/>

        <service id="JoostGroen\Mentat\Service\Llm\PromptBuilder"/>

        <service id="JoostGroen\Mentat\Service\Llm\ResultValidator"/>

        <service id="JoostGroen\Mentat\Service\Listing\DescriptionRenderer"/>

        <service id="JoostGroen\Mentat\Service\Listing\ProductDraftWriter">
            <argument type="service" id="product.repository"/>
            <argument type="service" id="tax.repository"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Listing\DescriptionRenderer"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="JoostGroen\Mentat\Controller\Admin\ListingDraftController" public="true">
            <argument type="service" id="mentat_category.repository"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Llm\PromptBuilder"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Llm\LlmClientInterface"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Llm\ResultValidator"/>
            <argument type="service" id="JoostGroen\Mentat\Service\Listing\ProductDraftWriter"/>
        </service>

    </services>
</container>